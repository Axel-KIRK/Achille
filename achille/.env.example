# Achille — Variables d'environnement
# Copier en .env et remplir les valeurs

# Telegram — créer un bot via @BotFather
TELEGRAM_BOT_TOKEN=
# Ton chat ID — envoie /start au bot, regarde les logs pour le trouver
AXEL_CHAT_ID=

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (pour Whisper) — https://platform.openai.com/
OPENAI_API_KEY=

# GitHub token (pour auto-push)
GITHUB_TOKEN=

# Path vers le clone du repo brain (les fichiers MD)
BRAIN_REPO_PATH=~/achille-brain
