# Achille — Variables d'environnement

# Telegram — créer un bot via @BotFather
TELEGRAM_BOT_TOKEN=
# Ton chat ID — envoie /start au bot, check https://api.telegram.org/bot<TOKEN>/getUpdates
AXEL_CHAT_ID=

# CLIProxyAPI — proxy local qui utilise ton abo Claude Max
# Lancer avec : cli-proxy-api serve
CLIPROXY_BASE_URL=http://127.0.0.1:8317/v1

# OpenAI (pour Whisper) — optionnel, pour les messages vocaux
OPENAI_API_KEY=

# Path vers le clone du repo brain (les fichiers MD)
BRAIN_REPO_PATH=~/achille-brain
